{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(linear *)",
      "Bash(ls*)",
      "Bash(pwd*)",
      "Bash(which*)",
      "Bash(whoami*)",
      "Bash(cat*)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(wc*)",
      "Bash(date*)",
      "Bash(env*)",
      "Bash(echo*)",
      "Bash(jq*)",
      "Bash(node *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(yarn *)",
      "Bash(pnpm *)",
      "Bash(python3 *)",
      "Bash(pip *)",
      "Bash(curl *)",
      "Bash(open *)",
      "Bash(cd *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(touch *)",
      "Bash(chmod *)",
      "Bash(dirname *)",
      "Bash(basename *)",
      "Bash(realpath *)",
      "Bash(sort*)",
      "Bash(uniq*)",
      "Bash(diff *)",
      "Bash(find *)",
      "Bash(xargs *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(tr *)",
      "Bash(cut *)",
      "Bash(tee *)",
      "WebFetch(*)",
      "WebSearch(*)",
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "Agent(*)"
    ],
    "ask": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git branch -D*)",
      "Bash(rm -rf*)",
      "Bash(kill*)",
      "Bash(pkill*)"
    ],
    "deny": [
      "Read(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.aws/**)",
      "Read(~/.kube/**)",
      "Read(~/.npmrc)",
      "Read(~/.git-credentials)",
      "Read(**/.env)",
      "Read(**/.env.*)"
    ]
  },
  "model": "opus[1m]",
  "language": "japanese",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "COMMAND=$(jq -r '.tool_input.command' < /dev/stdin); if echo \"$COMMAND\" | grep -qE 'rm\\s+-rf\\s+(/|~|\\$HOME)'; then echo 'ルートやホームディレクトリへの rm -rf はブロックされました' >&2; exit 2; fi; exit 0"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "COMMAND=$(jq -r '.tool_input.command' < /dev/stdin); if echo \"$COMMAND\" | grep -qE 'git\\s+push\\s+(-f|--force).*(main|master)'; then echo 'main/master への force push はブロックされました' >&2; exit 2; fi; exit 0"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); MSG=$(echo \"$INPUT\" | jq -r '.message // \"Claude Code からの通知\"'); osascript -e \"display notification \\\"$MSG\\\" with title \\\"Claude Code\\\"\" 2>/dev/null; exit 0"
          }
        ]
      }
    ]
  },
  "statusLine": {},
  "enabledPlugins": {}
}
